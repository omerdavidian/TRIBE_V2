# Required
NEXT_PUBLIC_API_URL=http://localhost:3001

# Coming-soon mode (set to "true" to gate the landing page)
COMING_SOON_MODE=false

# Comma-separated hosts that should be gated when COMING_SOON_MODE=true
# Example: tribewishlist.com,www.tribewishlist.com
PRODUCTION_HOSTS=tribewishlist.com,www.tribewishlist.com

# Vercel Edge Config (pulled automatically from Vercel dashboard)
# Run: vercel env pull
# Used for: feature flags, maintenance mode, dynamic configuration
# EDGE_CONFIG=<your-edge-config-connection-string>

# Database & Storage (Optional if handled by API)
DATABASE_URL=
DATABASE_URL_UNPOOLED=
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Google OAuth callback (must match what you set in Google Console)
# NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
