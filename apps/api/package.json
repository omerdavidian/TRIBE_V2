{
  "name": "@tribe/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/apps/api/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/apps/api/src/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "admin:bootstrap": "tsx src/scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@neondatabase/serverless": "^0.10.4",
    "@tribe/shared": "*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.29.1",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^5.9.6",
    "resend": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "drizzle-kit": "^0.28.1",
    "pino-pretty": "^13.0.0",
    "tsx": "4.7.0",
    "typescript": "^5.7.2"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  }
}
